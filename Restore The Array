#include <iostream>
#include <vector>
#include <string>

using namespace std;

class Solution {
public:
    int numberOfArrays(string s, int k) {
        int n = s.size();
        int mod = 1e9 + 7;
      
        vector<int> dp(n + 1, 0);
        
      
        dp[n] = 1;

  
        for (int i = n - 1; i >= 0; --i) {
           
            if (s[i] == '0') {
                dp[i] = 0;
                continue;
            }

            long long currentNum = 0;
          
            for (int j = i; j < n; ++j) {
                currentNum = currentNum * 10 + (s[j] - '0');
                
               
                if (currentNum > k) break;
                
              
                dp[i] = (dp[i] + dp[j + 1]) % mod;
                
                
                if (j - i >= 10) break; 
            }
        }

        return dp[0];
    }
};
