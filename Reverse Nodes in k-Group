class Solution {
public:
    ListNode* reverseKGroup(ListNode* head, int k) {
        if (!head || k == 1) return head;

        // Dummy node helps manage the new head of the list
        ListNode* dummy = new ListNode(0);
        dummy->next = head;

        ListNode* curr = dummy, *nex = dummy, *pre = dummy;
        int count = 0;

        // Count total nodes in the list
        while (curr->next) {
            curr = curr->next;
            count++;
        }

        // Process chunks of size k
        while (count >= k) {
            curr = pre->next; // Start of the current k-group
            nex = curr->next; // The node to be moved
            
            // Standard reversal for k-1 links within the group
            for (int i = 1; i < k; i++) {
                curr->next = nex->next;
                nex->next = pre->next;
                pre->next = nex;
                nex = curr->next;
            }
            
            pre = curr; // Move pre to the end of the reversed group
            count -= k;
        }

        ListNode* res = dummy->next;
        delete dummy;
        return res;
    }
};
